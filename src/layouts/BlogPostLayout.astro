---
import type { CollectionEntry } from "astro:content";

import GiscusComments from "../components/blog/GiscusComments.astro";
import PostMeta from "../components/blog/PostMeta.astro";
import { withBasePath } from "../lib/paths";
import { getProfile } from "../lib/profile";
import { getReadingTimeLabel } from "../lib/reading-time";
import { DEFAULT_OG_IMAGE } from "../lib/site";
import { createBlogPostingJsonLd, createPersonJsonLd } from "../lib/structured-data";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const profile = await getProfile();
const socialImage = post.data.heroImage ?? DEFAULT_OG_IMAGE;
const pageTitle = post.data.seoTitle ?? post.data.title;
const pageDescription = post.data.seoDescription ?? post.data.summary;
const readingTime = getReadingTimeLabel(post.body);
const heroImageSrc = post.data.heroImage
  ? /^https?:\/\//.test(post.data.heroImage)
    ? post.data.heroImage
    : withBasePath(post.data.heroImage)
  : null;
const articleModifiedTime = (post.data.updated ?? post.data.created).toISOString();
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={socialImage}
  ogType="article"
  canonicalUrl={post.data.canonicalUrl}
  articlePublishedTime={post.data.created.toISOString()}
  articleModifiedTime={articleModifiedTime}
  articleTags={post.data.tags}
  structuredData={[createPersonJsonLd(profile), createBlogPostingJsonLd(post, profile)]}
  pageClass="page-article"
>
  <article class="article-shell">
    <a class="back-link" href={withBasePath("/blog/")}>Back to blog</a>
    <div class="article-frame surface">
      <header class="article-hero">
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-lead">{post.data.summary}</p>
        <span class="section-rule" aria-hidden="true"></span>
        <PostMeta
          created={post.data.created}
          updated={post.data.updated}
          tags={post.data.tags}
          readingTime={readingTime}
        />
        {
          heroImageSrc && (
            <img
              class="article-hero-media"
              src={heroImageSrc}
              alt={`${post.data.title} hero image`}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          )
        }
      </header>
      <section class="article-content">
        <slot />
      </section>
      <GiscusComments />
    </div>
  </article>
</BaseLayout>
