---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";

import { formatDate } from "../lib/dates";
import { withBasePath } from "../lib/paths";
import { getProfile } from "../lib/profile";
import { DEFAULT_OG_IMAGE } from "../lib/site";
import { createPersonJsonLd, createSpeakingJsonLd } from "../lib/structured-data";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  entry: CollectionEntry<"speaking">;
}

type ImageModule = {
  default: ImageMetadata | string;
};

const speakingImages = import.meta.glob<ImageModule>(
  "../content/speaking/**/*.{avif,gif,jpeg,jpg,png,svg,webp}",
  { eager: true },
);

const { entry } = Astro.props;
const profile = await getProfile();
const heroImageSrc = entry.data.heroImage ? getSpeakingImageSrc(entry, entry.data.heroImage) : null;
const socialImage = heroImageSrc ?? DEFAULT_OG_IMAGE;
const articleModifiedTime = (entry.data.updated ?? entry.data.created).toISOString();
const updatedLabel =
  entry.data.updated && entry.data.updated.getTime() !== entry.data.created.getTime()
    ? formatDate(entry.data.updated)
    : null;

function getSpeakingImageSrc(speakingEntry: CollectionEntry<"speaking">, imagePath: string): string {
  if (/^https?:\/\//.test(imagePath)) {
    return imagePath;
  }

  if (imagePath.startsWith("/")) {
    return withBasePath(imagePath);
  }

  const normalizedEntryId = speakingEntry.id.replaceAll("\\", "/");
  const entryDirectory = normalizedEntryId.split("/").slice(0, -1).join("/");
  const normalizedImagePath = imagePath.replace(/^\.\//, "");
  const imageKey = `../content/speaking/${entryDirectory}/${normalizedImagePath}`;
  const image = speakingImages[imageKey]?.default;

  if (!image) {
    throw new Error(
      `Speaking heroImage "${imagePath}" could not be resolved relative to ${speakingEntry.id}.`,
    );
  }

  return typeof image === "string" ? image : image.src;
}
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  ogImage={socialImage}
  ogType="article"
  canonicalUrl={entry.data.canonicalUrl}
  articlePublishedTime={entry.data.created.toISOString()}
  articleModifiedTime={articleModifiedTime}
  articleTags={entry.data.tags}
  structuredData={[
    createPersonJsonLd(profile),
    createSpeakingJsonLd(entry, profile, { imageUrl: heroImageSrc }),
  ]}
  pageClass="page-article page-speaking-detail"
>
  <article class="article-shell">
    <a class="back-link" href={withBasePath("/speaking/")}>Back to Speaking</a>
    <div class="article-frame surface">
      <header class="article-hero">
        <h1 class="article-title">{entry.data.title}</h1>
        <p class="article-lead">{entry.data.summary}</p>
        <span class="section-rule" aria-hidden="true"></span>
        <div class="post-meta-block">
          <p class="post-meta">
            <span>{entry.data.event}</span>
            <time datetime={entry.data.created.toISOString()}>{formatDate(entry.data.created)}</time>
            {entry.data.location && <span>{entry.data.location}</span>}
            {updatedLabel && <span>Updated {updatedLabel}</span>}
          </p>
          {
            entry.data.tags && entry.data.tags.length > 0 && (
              <ul class="post-tags" aria-label="Tags">
                {entry.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )
          }
        </div>
        {
          heroImageSrc && (
            <img
              class="article-hero-media"
              src={heroImageSrc}
              alt={`${entry.data.title} session image`}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          )
        }
      </header>
      <section class="article-content">
        <slot />
      </section>
    </div>
  </article>
</BaseLayout>
