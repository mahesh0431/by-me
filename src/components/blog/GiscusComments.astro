---
import { SITE_ORIGIN } from "../../lib/site";

const isLocalPreview = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
const lightGiscusTheme = isLocalPreview
  ? "light"
  : new URL("/giscus-theme.css?v=20260426", SITE_ORIGIN).toString();
const darkGiscusTheme = isLocalPreview
  ? "dark"
  : new URL("/giscus-theme-dark.css?v=20260426", SITE_ORIGIN).toString();
---

<section
  class="article-comments"
  aria-labelledby="article-comments-title"
  data-giscus-comments-root
  data-giscus-light-theme={lightGiscusTheme}
  data-giscus-dark-theme={darkGiscusTheme}
>
  <h2 id="article-comments-title" class="article-comments__title">Comments</h2>
  <div class="article-comments__frame" data-giscus-frame></div>
  <script is:inline>
    (() => {
      const roots = document.querySelectorAll("[data-giscus-comments-root]");

      roots.forEach((root) => {
        if (!(root instanceof HTMLElement) || root.dataset.giscusThemeBound === "true") {
          return;
        }

        root.dataset.giscusThemeBound = "true";
        const lightTheme = root.dataset.giscusLightTheme ?? "light";
        const darkTheme = root.dataset.giscusDarkTheme ?? "dark";
        const getTheme = () => (document.documentElement.dataset.theme === "dark" ? darkTheme : lightTheme);

        const createGiscusScript = () => {
          const frame = root.querySelector("[data-giscus-frame]");

          if (!(frame instanceof HTMLElement) || frame.dataset.giscusScriptMounted === "true") {
            return;
          }

          frame.dataset.giscusScriptMounted = "true";
          const script = document.createElement("script");
          const attrs = {
            src: "https://giscus.app/client.js",
            "data-repo": "mahesh0431/by-me",
            "data-repo-id": "R_kgDORU4UvQ",
            "data-category": "Announcements",
            "data-category-id": "DIC_kwDORU4Uvc4C7uD-",
            "data-mapping": "pathname",
            "data-strict": "1",
            "data-reactions-enabled": "0",
            "data-emit-metadata": "0",
            "data-input-position": "top",
            "data-theme": getTheme(),
            "data-lang": "en",
            "data-loading": "lazy",
            crossorigin: "anonymous",
          };

          Object.entries(attrs).forEach(([name, value]) => {
            script.setAttribute(name, value);
          });
          script.async = true;
          frame.append(script);
        };

        const sendTheme = () => {
          const iframe = root.querySelector("iframe.giscus-frame");

          if (!(iframe instanceof HTMLIFrameElement) || !iframe.contentWindow) {
            return;
          }

          iframe.contentWindow.postMessage(
            {
              giscus: {
                setConfig: {
                  reactionsEnabled: false,
                  theme: getTheme(),
                },
              },
            },
            "https://giscus.app",
          );
        };

        const scheduleThemeSync = () => {
          sendTheme();
          window.setTimeout(sendTheme, 100);
          window.setTimeout(sendTheme, 500);
        };

        const bindIframe = () => {
          const iframe = root.querySelector("iframe.giscus-frame");

          if (!(iframe instanceof HTMLIFrameElement) || iframe.dataset.giscusThemeListener === "true") {
            return;
          }

          iframe.dataset.giscusThemeListener = "true";
          iframe.addEventListener("load", scheduleThemeSync);
          scheduleThemeSync();
        };

        const rootObserver = new MutationObserver(() => {
          bindIframe();
        });
        rootObserver.observe(root, { childList: true, subtree: true });

        const themeObserver = new MutationObserver(() => {
          scheduleThemeSync();
        });
        themeObserver.observe(document.documentElement, {
          attributeFilter: ["data-theme"],
          attributes: true,
        });

        createGiscusScript();
        bindIframe();
      });
    })();
  </script>
</section>
