---
import { formatDate } from '../../lib/dates';

interface Props {
  created: Date;
  updated?: Date;
  tags?: string[];
  readingTime?: string;
  compact?: boolean;
  showTags?: boolean;
}

const {
  created,
  updated,
  tags = [],
  readingTime,
  compact = false,
  showTags = true,
} = Astro.props;

const updatedLabel = updated && updated.getTime() !== created.getTime() ? formatDate(updated) : undefined;
---

<div class:list={["post-meta-block", { "post-meta-block--compact": compact }]}>
  <p class="post-meta">
    <time datetime={created.toISOString()}>{formatDate(created)}</time>
    {readingTime && <span>{readingTime} read</span>}
    {updatedLabel && <span>Updated {updatedLabel}</span>}
  </p>
  {
    showTags && tags.length > 0 && (
      <ul class="post-tags" aria-label="Tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</div>
