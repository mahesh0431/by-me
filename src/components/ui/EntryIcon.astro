---
interface Props {
  name?: "spark" | "structure" | "book" | "note" | "disclaimer" | "mic";
}

const { name = "spark" } = Astro.props;
---

<span class="entry-icon" aria-hidden="true">
  {
    name === "spark" ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4.5 13.8 9l4.7 1.8-4.7 1.8L12 17l-1.8-4.4L5.5 10.8 10.2 9 12 4.5Z" />
      </svg>
    ) : name === "structure" ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6.5 19V8.5h11V19" />
        <path d="M4 19h16" />
        <path d="M9 8.5V5h6v3.5" />
        <path d="M9 12h.01" />
        <path d="M12 12h.01" />
        <path d="M15 12h.01" />
        <path d="M9 15h.01" />
        <path d="M12 15h.01" />
        <path d="M15 15h.01" />
      </svg>
    ) : name === "book" ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4.5 6.5A2.5 2.5 0 0 1 7 4h11v15.5a2.5 2.5 0 0 0-2.5-2.5H4.5Z" />
        <path d="M18 19.5A2.5 2.5 0 0 0 15.5 17H4.5V6.5" />
        <path d="M12 4v13" />
      </svg>
    ) : name === "disclaimer" ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4.5 19 8.5v7L12 19.5 5 15.5v-7L12 4.5Z" />
        <path d="M12 9v4.25" />
        <path d="M12 15.9h.01" />
      </svg>
    ) : name === "mic" ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4.5a3 3 0 0 1 3 3v4a3 3 0 0 1-6 0v-4a3 3 0 0 1 3-3Z" />
        <path d="M6.8 11.5a5.2 5.2 0 0 0 10.4 0" />
        <path d="M12 16.7v2.8" />
        <path d="M8.8 19.5h6.4" />
      </svg>
    ) : (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 4.5h10A1.5 1.5 0 0 1 18.5 6v12A1.5 1.5 0 0 1 17 19.5H7A1.5 1.5 0 0 1 5.5 18V6A1.5 1.5 0 0 1 7 4.5Z" />
        <path d="M8.5 9h7" />
        <path d="M8.5 12h7" />
        <path d="M8.5 15h4.5" />
      </svg>
    )
  }
</span>
