---
import { LINKEDIN_URL, X_URL } from '../../lib/site';
import IconLinkedIn from '../icons/IconLinkedIn.astro';
import IconX from '../icons/IconX.astro';
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <span>© 2026</span>
    <div class="site-footer__links" aria-label="Social links">
      <a href={LINKEDIN_URL} target="_blank" rel="noreferrer" aria-label="LinkedIn">
        <IconLinkedIn size={18} />
      </a>
      <a href={X_URL} target="_blank" rel="noreferrer" aria-label="X (Twitter)">
        <IconX size={18} />
      </a>
    </div>
  </div>
</footer>
