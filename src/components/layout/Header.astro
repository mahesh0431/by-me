---
import { withBasePath } from '../../lib/paths';
import { SITE_NAME } from '../../lib/site';
import ThemeToggle from '../ui/ThemeToggle.astro';
import NavLink from './NavLink.astro';

const normalizePath = (value: string): string => (value !== '/' ? value.replace(/\/$/, '') : value);
const currentPath = normalizePath(Astro.url.pathname);
const homePath = normalizePath(withBasePath('/'));
const aboutPath = normalizePath(withBasePath('/about/'));
const blogPath = normalizePath(withBasePath('/blog/'));
const legacyArchivePath = normalizePath(withBasePath('/blog/archive/'));
const isBlog =
  currentPath === blogPath ||
  currentPath === legacyArchivePath ||
  currentPath.startsWith(`${blogPath}/`);
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__left">
      <a class="site-brand" href={withBasePath('/')} aria-label={SITE_NAME}>
        <span class="site-brand__mark">MP</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <NavLink href="/" isActive={currentPath === homePath}>Home</NavLink>
        <NavLink href="/about/" isActive={currentPath === aboutPath}>About</NavLink>
        <NavLink href="/blog/" isActive={isBlog}>Blog</NavLink>
      </nav>
    </div>

    <div class="site-header__actions">
      <ThemeToggle />
    </div>
  </div>
</header>
