---
import { withBasePath } from '../../lib/paths';
import { SITE_ORIGIN } from '../../lib/site';

const speakingPath = withBasePath('/speaking/2026-03-25-agentic-ai-sap-inside-track-bengaluru/');
const canonicalUrl = new URL(speakingPath, SITE_ORIGIN).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${speakingPath}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonicalUrl} />
    <title>Redirecting to Speaking</title>
  </head>
  <body>
    <p>
      This note now lives under Speaking.
      <a href={speakingPath}>Continue</a>
    </p>
  </body>
</html>
