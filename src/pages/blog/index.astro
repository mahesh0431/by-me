---
import { withBasePath } from "../../lib/paths";

const archivePath = withBasePath("/blog/archive/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${archivePath}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={archivePath} />
    <title>Redirecting to archive</title>
  </head>
  <body>
    <p>
      Redirecting to the archive.
      <a href={archivePath}>Continue</a>
    </p>
  </body>
</html>
