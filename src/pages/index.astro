---
import { withBasePath } from '../lib/paths';
import { LINKEDIN_URL, X_URL } from '../lib/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import IconLinkedIn from '../components/icons/IconLinkedIn.astro';
import IconX from '../components/icons/IconX.astro';
---

<BaseLayout title="Home" description="Personal website and blog home page.">
  <section class="home-intro">
    <div class="home-intro__row">
      <img
        src={withBasePath('/images/mahesh.png')}
        alt="Mahesh Palavalli"
        class="home-intro__avatar"
        width="88"
        height="88"
      />
      <div>
        <h1 class="section-heading">Hi, I'm Mahesh</h1>
        <p class="section-copy">
          Solutions architect at SAP. I write here about tech, AI, architecture, and things I learn along the way.
        </p>
        <div class="home-intro__social">
          <a href={LINKEDIN_URL} target="_blank" rel="noreferrer" aria-label="LinkedIn">
            <IconLinkedIn size={20} />
          </a>
          <a href={X_URL} target="_blank" rel="noreferrer" aria-label="X (Twitter)">
            <IconX size={20} />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
