---
import PostCard from '../components/blog/PostCard.astro';
import { withBasePath } from '../lib/paths';
import { getBlogPosts } from '../lib/blog';
import { getProfile } from '../lib/profile';
import { createPersonJsonLd, createWebSiteJsonLd } from '../lib/structured-data';
import BaseLayout from '../layouts/BaseLayout.astro';

const profile = await getProfile();
const recentPosts = (await getBlogPosts())
  .filter((post) => !post.data.tags?.includes('archive'))
  .slice(0, 5);
const pageDescription =
  'Mahesh Palavalli is an AI Solutions Architect at SAP, writing about generative AI, SAP architecture, agentic systems, and enterprise technology.';
---

<BaseLayout
  title={profile.data.name}
  description={pageDescription}
  structuredData={[createWebSiteJsonLd(), createPersonJsonLd(profile)]}
  pageClass="page-home"
>
  <section class="home-hero surface surface--hero">
    <div class="home-hero__art" aria-hidden="true">
      <span class="home-hero__beam home-hero__beam--one"></span>
      <span class="home-hero__beam home-hero__beam--two"></span>
      <span class="home-hero__beam home-hero__beam--three"></span>
      <span class="home-hero__grid"></span>
    </div>

    <div class="home-hero__portrait">
      <img
        src={withBasePath(profile.data.avatar)}
        alt={profile.data.name}
        class="home-hero__avatar"
        width="240"
        height="240"
      />
    </div>

    <div class="home-hero__content">
      <h1 class="display-title">{profile.data.homeHeading}</h1>
      <span class="section-rule" aria-hidden="true"></span>
      <p class="hero-copy">
        {profile.data.homeIntro}
        <a class="home-hero__link" href={withBasePath('/about/')}>
          More about me
          <span aria-hidden="true">&rarr;</span>
        </a>
      </p>
    </div>
  </section>

  <section class="section-head">
    <div>
      <h2 class="section-title">Recent posts</h2>
    </div>
    <a class="section-link" href={withBasePath('/blog/')}>View blog</a>
  </section>

  <section class="entry-list entry-list--home">
    {recentPosts.map((post, index) => (
      <PostCard post={post} index={index} variant="home" />
    ))}
  </section>
</BaseLayout>
