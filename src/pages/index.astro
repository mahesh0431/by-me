---
import PostCard from '../components/blog/PostCard.astro';
import { withBasePath } from '../lib/paths';
import { getBlogPosts } from '../lib/blog';
import { getProfile } from '../lib/profile';
import { LINKEDIN_URL, X_URL } from '../lib/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import IconLinkedIn from '../components/icons/IconLinkedIn.astro';
import IconX from '../components/icons/IconX.astro';

const profile = await getProfile();
const recentPosts = (await getBlogPosts())
  .filter((post) => !post.data.tags?.includes('archive'))
  .slice(0, 5);
---

<BaseLayout title="Home" description="Personal website and blog home page.">
  <section class="home-intro">
    <div class="home-intro__row">
      <img
        src={withBasePath(profile.data.avatar)}
        alt={profile.data.name}
        class="home-intro__avatar"
        width="88"
        height="88"
      />
      <div>
        <h1 class="section-heading">{profile.data.homeHeading}</h1>
        <p class="section-copy">
          {profile.data.homeIntro}
        </p>
        <div class="home-intro__social">
          <a href={LINKEDIN_URL} target="_blank" rel="noreferrer" aria-label="LinkedIn">
            <IconLinkedIn size={20} />
          </a>
          <a href={X_URL} target="_blank" rel="noreferrer" aria-label="X (Twitter)">
            <IconX size={20} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-card">
    <h2 class="section-heading">Recent Posts</h2>
  </section>

  <section class="post-grid">
    {recentPosts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>

  <p style="margin-top: 1.5rem;">
    <a href={withBasePath('/blog/')}>View all posts →</a>
  </p>
</BaseLayout>
