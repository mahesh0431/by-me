---
import RecentEntryCard from '../components/home/RecentEntryCard.astro';
import { withBasePath } from '../lib/paths';
import { getBlogPosts, getPostRouteSlug } from '../lib/blog';
import { formatDate } from '../lib/dates';
import { getProfile } from '../lib/profile';
import { getSpeakingEntries, getSpeakingRouteSlug } from '../lib/speaking';
import { createPersonJsonLd, createWebSiteJsonLd } from '../lib/structured-data';
import BaseLayout from '../layouts/BaseLayout.astro';

const profile = await getProfile();
const recentPosts = (await getBlogPosts())
  .filter((post) => !post.data.tags?.includes('archive'))
  .map((post) => ({
    kind: 'post' as const,
    title: post.data.title,
    summary: post.data.summary,
    href: withBasePath(`/blog/${getPostRouteSlug(post)}/`),
    date: post.data.created,
    meta: 'Blog',
  }));
const recentSpeaking = (await getSpeakingEntries()).map((entry) => ({
  kind: 'speaking' as const,
  title: entry.data.title,
  summary: entry.data.summary,
  href: entry.data.sourceUrl ?? withBasePath(`/speaking/#${getSpeakingRouteSlug(entry)}`),
  date: entry.data.created,
  meta: entry.data.event,
}));
const recentEntries = [...recentPosts, ...recentSpeaking]
  .sort((left, right) => right.date.getTime() - left.date.getTime())
  .slice(0, 5);
const pageDescription =
  'Mahesh Palavalli is an AI Solutions Architect at SAP, writing about generative AI, SAP architecture, agentic systems, and enterprise technology.';
---

<BaseLayout
  title={profile.data.name}
  description={pageDescription}
  structuredData={[createWebSiteJsonLd(), createPersonJsonLd(profile)]}
  pageClass="page-home"
>
  <section class="home-hero surface surface--hero">
    <div class="home-hero__art" aria-hidden="true">
      <span class="home-hero__beam home-hero__beam--one"></span>
      <span class="home-hero__beam home-hero__beam--two"></span>
      <span class="home-hero__beam home-hero__beam--three"></span>
      <span class="home-hero__grid"></span>
    </div>

    <div class="home-hero__portrait">
      <img
        src={withBasePath(profile.data.avatar)}
        alt={profile.data.name}
        class="home-hero__avatar"
        width="240"
        height="240"
      />
    </div>

    <div class="home-hero__content">
      <h1 class="display-title">{profile.data.homeHeading}</h1>
      <span class="section-rule" aria-hidden="true"></span>
      <p class="hero-copy">
        {profile.data.homeIntro}
        <a class="home-hero__link" href={withBasePath('/about/')}>
          More about me
          <span aria-hidden="true">&rarr;</span>
        </a>
      </p>
    </div>
  </section>

  <section class="section-head">
    <div>
      <h2 class="section-title">Recent</h2>
      <p class="section-kicker">Writing and speaking notes, clearly marked so they do not pretend to be the same thing.</p>
    </div>
  </section>

  <section class="recent-list entry-list--home">
    {recentEntries.map((entry, index) => (
      <RecentEntryCard
        kind={entry.kind}
        title={entry.title}
        summary={entry.summary}
        href={entry.href}
        dateLabel={formatDate(entry.date)}
        dateIso={entry.date.toISOString()}
        meta={entry.meta}
        index={index}
      />
    ))}
  </section>
</BaseLayout>
